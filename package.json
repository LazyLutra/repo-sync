{
  "name": "repo-sync",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": "LazyLutra",
  "description": "A lightweight, cross-platform Git repository batch management tool.",
  "license": "GPL-3.0",
  "keywords": [
    "git",
    "electron",
    "vue3",
    "typescript",
    "batch-management",
    "reposync"
  ],
  "homepage": "https://github.com/LazyLutra/repo-sync#readme",
  "bugs": {
    "url": "https://github.com/LazyLutra/repo-sync/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LazyLutra/repo-sync.git"
  },
  "scripts": {
    "dev": "vite",
    "clean": "rimraf dist dist-electron release",
    "build": "vue-tsc && vite build && electron-builder",
    "build:win": "vue-tsc && vite build && electron-builder --win --x64",
    "build:dir": "vue-tsc && vite build && electron-builder --dir",
    "preview": "vite preview"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.6",
    "electron-store": "^11.0.2",
    "lucide-vue-next": "^0.574.0",
    "p-limit": "^5.0.0",
    "pinia": "^3.0.4",
    "simple-git": "^3.32.2",
    "vue": "^3.4.21",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.26"
  },
  "main": "dist-electron/index.js"
}
